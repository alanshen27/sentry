// Sentry — Postgres schema (production). When DATABASE_URL is unset the app
// falls back to a local JSON-backed repository so the demo runs without infra.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?  // local auth only (Supabase auth stores passwords remotely)
  name         String?
  role         String   @default("analyst") // admin | analyst | viewer
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships     WorkspaceMember[]
  ownedWorkspaces Workspace[]      @relation("WorkspaceOwner")
  projects        Project[]        @relation("ProjectOwner")
  segments        Segment[]
  markers         Marker[]
  zones           WatchZone[]      @relation("ZoneOwner")
  alerts          AlertRecord[]
  apiKeys         ApiKey[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members  WorkspaceMember[]
  projects Project[]
  triggers TriggerRule[]
  alerts   AlertRecord[]
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        String   @default("analyst") // admin | analyst | viewer
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

model Project {
  id           String   @id @default(cuid())
  workspaceId  String
  ownerId      String
  name         String
  description  String?
  defaultLat   Float    @default(0.0)
  defaultLng   Float    @default(0.0)
  defaultZoom  Float    @default(2.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner     User        @relation("ProjectOwner", fields: [ownerId], references: [id])
  layers    Layer[]
  segments  Segment[]
  markers   Marker[]
  zones     WatchZone[]
  snapshots AnalysisSnapshot[]

  @@index([workspaceId])
}

model Layer {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  type        String   @default("overlay") // overlay | segment | marker | reference
  color       String   @default("#38bdf8")
  visible     Boolean  @default(true)
  locked      Boolean  @default(false)
  createdAt   DateTime @default(now())

  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  segments Segment[]
  markers  Marker[]
  zones    WatchZone[]

  @@index([projectId])
}

model Segment {
  id          String   @id @default(cuid())
  projectId   String
  layerId     String?
  workspaceId String
  geometry    Json     // GeoJSON Polygon
  label       String?
  color       String   @default("#38bdf8")
  state       String   @default("active") // draft | active | archived
  riskScore   Float?
  notes       String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  layer     Layer?  @relation(fields: [layerId], references: [id], onDelete: SetNull)
  creator   User    @relation(fields: [createdBy], references: [id])

  @@index([projectId])
  @@index([layerId])
}

model Marker {
  id          String   @id @default(cuid())
  projectId   String
  layerId     String?
  workspaceId String
  geometry    Json     // GeoJSON Point
  label       String?
  color       String   @default("#f97316")
  state       String   @default("pending") // pending | verified | damaged | destroyed | unknown | safe
  category    String   @default("observation") // house | school | hospital | shelter | observation | fire | flood | custom
  sizeM2      Float?   // building footprint size (LLM house evaluation)
  confidence  Float?
  source      String   @default("user") // user | llm | vision | firms | usgs
  notes       String?
  createdBy   String
  statusHistory Json   @default("[]") // MarkerStatusEvent[]: { state, byId, byName, at } — audit trail of who set what status when
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  layer   Layer?  @relation(fields: [layerId], references: [id], onDelete: SetNull)
  creator User    @relation(fields: [createdBy], references: [id])

  @@index([projectId])
  @@index([layerId])
  @@index([state])
}

model WatchZone {
  id          String   @id @default(cuid())
  projectId   String?
  layerId     String?
  workspaceId String
  ownerId     String
  name        String
  geometry    Json     // GeoJSON Polygon
  hazards     Json     // HazardType[]
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  layer     Layer?        @relation(fields: [layerId], references: [id], onDelete: SetNull)
  owner     User          @relation("ZoneOwner", fields: [ownerId], references: [id])
  triggers  TriggerRule[]
  snapshots AnalysisSnapshot[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([layerId])
}

model TriggerRule {
  id               String   @id @default(cuid())
  workspaceId      String
  zoneId           String?
  name             String
  hazard           String
  metric           String
  operator         String
  threshold        Float
  durationMinutes  Int      @default(0)
  cooldownMinutes  Int      @default(30)
  actions          Json     // TriggerAction[]
  naturalLanguage  String
  enabled          Boolean  @default(true)
  lastFired        DateTime?
  createdAt        DateTime @default(now())

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  zone      WatchZone? @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([zoneId])
}

model AlertRecord {
  id            String   @id @default(cuid())
  workspaceId   String
  triggerId     String?
  zoneId        String?
  userId        String?
  triggerName   String
  zoneName      String?
  hazard        String
  message       String
  severity      String
  brief         Json?    // BriefResult
  actions       Json     // TriggerAction[]
  acknowledged  Boolean  @default(false)
  createdAt     DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@index([workspaceId])
  @@index([createdAt])
}

model AnalysisSnapshot {
  id        String   @id @default(cuid())
  zoneId    String?
  projectId String?
  result    Json     // AnalysisResult
  createdAt DateTime @default(now())

  zone    WatchZone? @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  project Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([zoneId])
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  provider  String   // openai | anthropic | openrouter | firms
  maskedKey String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// Shared, workspace-agnostic ingested hazard signals (written by the background
// ingest worker; read by the map for all users).
model HazardEventRecord {
  id         String   @id @default(cuid())
  source     String   // USGS | NASA_FIRMS | GDACS
  sourceId   String   // upstream stable id
  type       String   // HazardType
  geometry   Json     // GeoJSON Point
  severity   Float
  confidence Float
  observedAt DateTime
  properties Json
  ingestedAt DateTime @default(now())

  @@unique([source, sourceId])
  @@index([type])
  @@index([source])
  @@index([observedAt])
}

model IngestRun {
  id         String    @id @default(cuid())
  source     String
  count      Int
  ok         Boolean
  error      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([startedAt])
}
